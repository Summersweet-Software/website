---
import Base from "../layouts/Base.astro";
---

<Base title="About — Summersweet Software">
  <section class="max-w-7xl mx-auto px-6 lg:px-10 py-20">
    <p
      class="text-xs font-medium tracking-widest uppercase text-brand-light mb-3"
    >
      Who We Are
    </p>
    <h1
      class="font-[family-name:var(--font-display)] text-3xl font-semibold text-darkest mb-8"
    >
      About Us
    </h1>
    <div class="space-y-5 leading-relaxed text-brand-dark/70">
      <p>
        <strong class="text-darkest font-medium">Summersweet Software</strong> is
        a worker-owned cooperative focused on software engineering. Based in Maryland,
        USA, we build open-source tools and libraries that help developers ship better
        software.
      </p>
      <p>
        As a cooperative, every member has an equal voice in how we operate. We
        believe that shared ownership leads to better software, stronger teams,
        and more sustainable work.
      </p>

      <h2
        class="font-[family-name:var(--font-display)] text-xl font-semibold text-darkest mt-10"
      >
        Get Involved
      </h2>
      <p>
        We're always looking for contributors and collaborators. Join us on <a
          href="https://discord.gg/CZ3Hfpzdep"
          class="text-brand hover:underline">Discord</a
        > or check out our work on <a
          href="https://github.com/Summersweet-Software/"
          class="text-brand hover:underline">GitHub</a
        >.
      </p>
    </div>
  </section>
</Base>
