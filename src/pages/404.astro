---
import Base from "../layouts/Base.astro";
---

<Base title="Page Not Found — Summersweet Software">
  <section class="max-w-7xl mx-auto px-6 lg:px-10 py-32 text-center">
    <h1 class="text-6xl font-bold text-darkest mb-4">404</h1>
    <p class="text-brand-light mb-8">
      The page you’re looking for doesn’t exist.
    </p>
    <a
      href="/"
      class="inline-block px-5 py-2.5 bg-brand-dark text-sand text-sm font-medium tracking-wider hover:bg-darkest transition-colors"
      >Back Home</a
    >
  </section>
</Base>
